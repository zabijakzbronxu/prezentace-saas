# Zkopíruj tento soubor jako `.env.local` a vyplň skutečné hodnoty.
# POZOR: .env.local se NIKDY nenahrává do gitu (je v .gitignore). Klíče drž v tajnosti.
# Přesný návod, kde co vzít, je v tasks/kroky-pro-karla.md.

# --- Supabase (databáze a přihlašování) ------------------------------------
# Supabase → Project Settings → Data API (URL) a → API Keys (anon key)
NEXT_PUBLIC_SUPABASE_URL=https://TVUJ-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TVUJ-ANON-KEY

# Servisní klíč (Supabase → Project Settings → API Keys → service_role).
# Obchází veškerá bezpečnostní pravidla — smí ho vidět JEN server.
# Bez něj nejde zapsat platbu → nikdo nic nezveřejní.
# NIKDY ho nedávej do proměnné začínající NEXT_PUBLIC_ (to by ho poslalo do prohlížeče).
SUPABASE_SERVICE_ROLE_KEY=TVUJ-SERVICE-ROLE-KEY

# --- Stripe (platby) --------------------------------------------------------
# Stripe → Developers → API keys. V testovacím režimu začínají sk_test_,
# na ostro sk_live_. Nikdy je nevkládej do kódu.
STRIPE_SECRET_KEY=sk_test_...

# Podpisový klíč webhooku. Lokálně ho vypíše `stripe listen`,
# na ostro ho najdeš u endpointu ve Stripe dashboardu (Webhooks).
# Bez něj se webhook odmítne — a bez webhooku se nic nezveřejní.
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Cena za zveřejnění -----------------------------------------------------
# V celých korunách. Změna ceny = změna téhle proměnné (žádný zásah do kódu).
# Minimum je 15 Kč (nižší částku Stripe neúčtuje). Když necháš prázdné, platí 490 Kč.
PUBLISH_PRICE_CZK=490

# Název položky, který zákazník uvidí na platební stránce i na účtence.
PUBLISH_PRODUCT_NAME=Zveřejnění prezentace nemovitosti

# --- Adresa webu ------------------------------------------------------------
# Kam se zákazník vrátí po platbě. Lokálně http://localhost:3000,
# na ostro skutečná adresa (https://...). Na produkci je POVINNÁ.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
